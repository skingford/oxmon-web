NEXT_PUBLIC_DEFAULT_LOCALE=zh

# API base URL (loaded from the active env file by Next.js)
# development: .env.development(.local)
# production build/runtime: .env.production(.local)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_OX_APP_ID=oxmon-web
# HTML preview rendering thresholds for AI report detail page
# - lazy threshold: above this size (chars), preview is prepared during idle time
# - manual threshold: above this size (chars), preview requires explicit user action
NEXT_PUBLIC_AI_HTML_PREVIEW_LAZY_THRESHOLD=180000
NEXT_PUBLIC_AI_HTML_PREVIEW_MANUAL_THRESHOLD=480000

# The following line seems to be a duplicate and may cause confusion. Consider removing it if not needed.
NEXT_PUBLIC_OX_APP_ID=testappid
